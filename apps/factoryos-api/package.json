{
  "name": "factoryos-api",
  "version": "0.1.0",
  "description": "FactoryOS MES Core API — work orders, modules, parts, production tracking",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts 2>&1 | pino-pretty --colorize --translateTime SYS:HH:MM:ss.l --ignore pid,hostname",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node --env-file=.env node_modules/node-pg-migrate/bin/node-pg-migrate.js up --database-url-var DB_URL",
    "migrate:down": "node --env-file=.env node_modules/node-pg-migrate/bin/node-pg-migrate.js down --database-url-var DB_URL",
    "migrate:create": "node --env-file=.env node_modules/node-pg-migrate/bin/node-pg-migrate.js create --database-url-var DB_URL -j sql",
    "db:types": "kysely-codegen --env-file=.env --url='env(DB_URL)' --dialect=postgres --default-schema=mes --exclude-pattern='public.*' --out-file=src/db/types.generated.ts",
    "imos:parse": "tsx src/adapters/imos/dev-cli.ts"
  },
  "keywords": [
    "factoryos",
    "mes",
    "manufacturing"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^5.2.1",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "kysely-codegen": "^0.20.0",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
