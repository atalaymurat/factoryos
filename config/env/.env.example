# =============================================================================
# FactoryOS Integration Service - Environment Variables (Example)
# =============================================================================
# Bu dosya repo'da commit edilir, GERÇEK değer içermez.
# Kullanım:
#   cp config/env/.env.example config/env/common.env
#   # değerleri gerçek ortamınıza göre düzenleyin
#
# İki env dosyası var:
#   - config/env/common.env → container içi (Node.js process.env.*)
#   - .env (repo kök)       → docker-compose.yml interpolation (port mapping vs.)
# =============================================================================

# ----- PostgreSQL (container içi) -----
POSTGRES_USER=factoryos
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=factoryos
DB_URL=postgres://factoryos:change_me_in_production@postgres:5432/factoryos

# ----- MQTT (container içi) -----
# docker-compose network'ünde service adı 'emqx'
MQTT_URL=mqtt://emqx:1883

# ----- Integration Service (container içi) -----
PORT=3000
LOG_LEVEL=info

# Worker tuning (opsiyonel, default'lar makul)
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=10
WORKER_MAX_ATTEMPTS=5

# ----- Docker Compose (.env dosyasına git — host port mapping) -----
# INTEGRATION_PORT=33002
# EMQX_DASHBOARD_PORT=33001